# Database
POSTGRES_PASSWORD=ocr123456
BACKEND_PORT=8000
FRONTEND_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379

# OCR runtime
OCR_USE_GPU=true
OCR_DEVICE=gpu:0
OCR_LANG=ch

# Auth
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=change-this-secret
AUTH_SESSION_TTL=28800

# ─── LLM Configuration (新配置，推荐使用) ───
# 支持所有 OpenAI 兼容 API: MiniMax / Ollama / vLLM / LocalAI
# 切换 Provider 只需改这里，无需改代码
LLM_BASE_URL=https://api.minimaxi.com/v1
LLM_API_KEY=
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_SECONDS=60
LLM_MAX_INPUT_CHARS=12000
#
# Ollama 本地部署示例:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=qwen2.5:14b
#
# vLLM 本地部署示例:
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=token-abc123
# LLM_MODEL=Qwen/Qwen2.5-14B-Instruct

# ─── MiniMax (旧配置，向后兼容，优先级低于 LLM_*) ───
MINIMAX_ENABLED=false
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT_SECONDS=60
MINIMAX_MAX_INPUT_CHARS=12000
MINIMAX_BATCH_CONCURRENCY=20

# Local filesystem access
# Only absolute paths under these roots may be scanned or processed by /scan-folder and /upload-from-path.
LOCAL_PATH_ROOTS=/app/uploads,/app/data

# Optional seed import
# INIT_ARCHIVE_EXCEL_PATH=/app/data/archive.xls
# INIT_ARCHIVE_BATCH_ID=init_import
