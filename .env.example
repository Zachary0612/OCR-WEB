# Database
POSTGRES_PASSWORD=ocr123456
BACKEND_PORT=8000
FRONTEND_PORT=80
POSTGRES_PORT=5432
REDIS_PORT=6379

# OCR runtime
OCR_USE_GPU=true
OCR_DEVICE=gpu:0
OCR_LANG=ch

# Auth
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SECRET=change-this-secret
AUTH_SESSION_TTL=28800

# MiniMax field extraction
MINIMAX_ENABLED=false
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TIMEOUT_SECONDS=60
MINIMAX_MAX_INPUT_CHARS=12000
MINIMAX_BATCH_CONCURRENCY=20

# Local filesystem access
# Only absolute paths under these roots may be scanned or processed by /scan-folder and /upload-from-path.
LOCAL_PATH_ROOTS=/app/uploads,/app/data

# Optional seed import
# INIT_ARCHIVE_EXCEL_PATH=/app/data/archive.xls
# INIT_ARCHIVE_BATCH_ID=init_import
